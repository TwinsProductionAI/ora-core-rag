{
    "module":  {
                   "id":  "ORA_CORE_RAG",
                   "version":  "1.2.0-public-draft",
                   "status":  "PUBLIC_DRAFT",
                   "type":  "canonical_retrieval_layer",
                   "role":  "Retrieve source-backed ORA canon context without storing client payloads.",
                   "depends_on":  [
                                      "ORCHESTRATEUR_LLM",
                                      "HGOV",
                                      "GPV2",
                                      "ORA_N6"
                                  ]
               },
    "authority_order":  [
                            "SYSTEM_OR_PROJECT_INSTRUCTIONS",
                            "ORCHESTRATEUR_LLM",
                            "HGOV_OR_PRIMORDIA",
                            "GPV2",
                            "ORA_CORE_RAG",
                            "CLIENT_RAG_WITH_VALID_ROUTE",
                            "EXAMPLES"
                        ],
    "core_invariants":  [
                            "ORA_CORE_RAG indexes ORA canon only",
                            "Client payloads must not be written into ORA_CORE_RAG",
                            "Client RAG access requires a valid GLK route manifest",
                            "No source means UNSURE, not invention",
                            "Retrieval traces must keep source ids and hashes"
                        ],
    "retrieval_policy":  {
                             "default_status_if_no_source":  "UNSURE",
                             "default_top_k":  5,
                             "source_required_for_factual_claims":  true,
                             "accepted_core_scope":  "ORA_CORE",
                             "deny_client_scope_in_core_index":  true
                         },
    "route_policy":  {
                         "route_id_required_for_client_rag":  true,
                         "route_id_format":  "GLK[TENANT:\u003cTENANT_ID\u003e:\u003cENV\u003e:v\u003cN\u003e]",
                         "cross_tenant_access":  "DENY",
                         "unscoped_client_memory":  "DENY",
                         "write_client_payload_to_core":  "DENY"
                     },
    "runtime_pipeline":  [
                             "LOAD_SOURCE_MANIFEST_OR_GITHUB_TREE",
                             "FETCH_OR_READ_SOURCE",
                             "HASH_SOURCE",
                             "CHUNK_SOURCE",
                             "INDEX_CHUNKS_FTS5",
                             "RETRIEVE_SOURCE_BACKED_CONTEXT",
                             "OPTIONAL_ORCHESTRATEUR_LLM_PACKET",
                             "OPTIONAL_JSONL_AUDIT",
                             "OPTIONAL_CLIENT_ROUTE_PLANNING",
                             "OPTIONAL_NEROFLUX_FANOUT_REGULATION"
                         ],
    "success_criteria":  [
                             "retrieves exact ORA module names",
                             "keeps source hashes stable",
                             "denies non-ORA_CORE document ingestion",
                             "denies client access without route",
                             "denies cross-tenant access",
                             "runs with Python standard library only"
                         ],
    "audit_policy":  {
                         "mode":  "optional_jsonl",
                         "store_private_client_payloads":  false,
                         "event_types":  [
                                             "document_indexed",
                                             "manifest_ingested",
                                             "github_repo_ingested",
                                             "query",
                                             "orchestrator_packet"
                                         ]
                     },
    "github_ingestion":  {
                             "mode":  "public_repo_tree_discovery",
                             "accepted_extensions":  [
                                                         ".md",
                                                         ".json",
                                                         ".txt",
                                                         ".py",
                                                         ".ps1",
                                                         ".psm1",
                                                         ".gpl",
                                                         ".gpv2"
                                                     ],
                             "output_scope":  "ORA_CORE"
                         },
    "orchestrator_connector":  {
                                   "module":  "ORA_CORE_RAG_ORCHESTRATOR_CONNECTOR",
                                   "returns":  [
                                                   "intent",
                                                   "risk_level",
                                                   "freshness_need",
                                                   "primary_module",
                                                   "verify_status",
                                                   "authority_path",
                                                   "retrieval"
                                               ]
                               },
    "multi_rag_registry":  {
                               "mode":  "route_gated_activation_plan",
                               "allowed_resource_types":  [
                                                              "rag",
                                                              "agent",
                                                              "llm"
                                                          ],
                               "client_scopes":  [
                                                     "TENANT",
                                                     "DEPARTMENT",
                                                     "PRIVATE_CASE"
                                                 ],
                               "can_answer_final":  false,
                               "cross_tenant_access":  "DENY"
                           },
    "neroflux_fanout":  {
                            "module":  "NEROFLUX_FANOUT_REGULATOR",
                            "inputs":  [
                                           "retrieval_pressure",
                                           "source_conflict",
                                           "permission_risk",
                                           "injection_risk",
                                           "latency_pressure",
                                           "cost_pressure",
                                           "client_sensitivity",
                                           "urgency",
                                           "agent_count",
                                           "contradiction"
                                       ],
                            "outputs":  [
                                            "pace",
                                            "max_rag_fanout",
                                            "top_k_per_rag",
                                            "require_hnerons",
                                            "require_human_review",
                                            "actions"
                                        ]
                        }
}
