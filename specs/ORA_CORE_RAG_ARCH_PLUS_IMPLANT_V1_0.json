    "private client profile payload",
    "unscoped tenant memory",
    "raw personal identifiers unless explicitly authorized and scoped"
  ],
  "cli": {
    "command": "arch-persona-activate",
    "payload_schema": "schemas/arch_persona_activation.schema.json",
    "example": "examples/arch_persona_activation.json"
  },
  "success_criteria": [
    "returns all six foundation groups",
    "preserves field source status",
    "denies more than four Personae",
    "denies more than four ARC++",
    "returns policy.client_payload_to_core DENY"
  ]
}
