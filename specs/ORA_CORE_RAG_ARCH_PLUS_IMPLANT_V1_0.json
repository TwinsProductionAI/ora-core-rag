    "type": "arch_plus_runtime_implant",
    "role": "Build route-gated ARCH+ ArchiPersona activation packets without writing client profile payloads into ORA core.",
    "binds_to": {
      "gpv2_module_id": "MODULE_ARCH_PLUS",
      "code_pos": "M10",
