      "variant_version": "3.0.0"
    }
  },
  "authority_order": [
    "SYSTEM_OR_PROJECT_INSTRUCTIONS",
    "HGOV_OR_PRIMORDIA",
    "GPV2_MODULE_ARCH_PLUS_M10",
    "ORA_CORE_RAG_ROUTE_GATE",
    "TENANT_PROFILE_STORE"
  ],
  "core_invariants": [
    "ARCH+ remains code position M10",
    "ArchiPersona activation requires a valid GLK tenant route",
